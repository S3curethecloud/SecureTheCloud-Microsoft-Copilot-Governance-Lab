{
  "title": "SecureTheCloud Copilot Governance Doctrine Alignment Report",
  "type": "object",
  "required": [
    "alignment_report",
    "canonical_repository",
    "consumption_mode",
    "authority_status",
    "module_registration_status",
    "suite_membership_claimed",
    "runtime_authority_claimed",
    "contract_paths",
    "checks",
    "claims_boundary"
  ],
  "properties": {
    "alignment_report": {"type": "string", "minLength": 1},
    "canonical_repository": {"type": "string", "minLength": 1},
    "consumption_mode": {"type": "string", "enum": ["downstream_reference_only"]},
    "authority_status": {"type": "string", "enum": ["no_runtime_authority"]},
    "module_registration_status": {"type": "string", "enum": ["unregistered_candidate"]},
    "suite_membership_claimed": {"type": "boolean", "enum": [false]},
    "runtime_authority_claimed": {"type": "boolean", "enum": [false]},
    "contract_paths": {"type": "array", "minItems": 5, "items": {"type": "string"}},
    "checks": {"type": "array", "minItems": 1},
    "claims_boundary": {"type": "string", "minLength": 1}
  }
}
