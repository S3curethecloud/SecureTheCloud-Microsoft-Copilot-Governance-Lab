    "workspace_mode",
    "platform_posture",
    "authority",
    "adoption_status",
    "summary_counts",
    "navigation",
    "control_groups",
    "priority_findings",
    "artifacts",
    "claims_boundary"
  ],
  "properties": {
    "workspace": {"type": "string", "minLength": 1},
    "workspace_mode": {"type": "string", "enum": ["static_simulation_shell"]},
