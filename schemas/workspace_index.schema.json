    "summary_counts": {"type": "object"},
    "navigation": {"type": "array", "minItems": 1},
    "control_groups": {"type": "object"},
    "priority_findings": {"type": "array"},
    "artifacts": {"type": "array", "minItems": 1},
    "claims_boundary": {"type": "string", "minLength": 1}
